# ==============================================================================
# Description: Configuration environment variables for the DNS Sinkhole.
# Version: 1.1.0
# Author: Alhasan Al-Hmondi
# ==============================================================================

# Upstream DNS server (where safe traffic is forwarded)
# Popular choices: 8.8.8.8 (Google), 1.1.1.1 (Cloudflare), 9.9.9.9 (Quad9)
UPSTREAM_DNS=8.8.8.8
UPSTREAM_PORT=53

# Time-to-live for cached DNS responses (in seconds). 300 = 5 minutes.
CACHE_TTL=300

# Auto-update interval for the blocklist (in seconds). 86400 = 24 hours.
BLOCKLIST_UPDATE_INTERVAL=86400